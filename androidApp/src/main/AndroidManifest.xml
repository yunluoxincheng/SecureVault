<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".SecureVaultApp"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SecureVault">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:resizeableActivity="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.securevault.autofill.SecureVaultAutofillService"
            android:exported="true"
            android:label="@string/autofill_service_label"
            android:permission="android.permission.BIND_AUTOFILL_SERVICE">
            <intent-filter>
                <action android:name="android.service.autofill.AutofillService" />
            </intent-filter>
            <meta-data
                android:name="android.autofill"
                android:resource="@xml/autofill_service_configuration" />
        </service>

        <activity
            android:name="com.securevault.autofill.ui.AutofillAuthActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.SecureVault" />
        <activity
            android:name="com.securevault.autofill.ui.AutofillSaveActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.SecureVault" />

    </application>

</manifest>